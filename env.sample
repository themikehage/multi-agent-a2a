# DashScope (Qwen) API - OpenAI compatible
DASHSCOPE_API_KEY=your_dashscope_api_key_here
MODEL_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
MODEL_NAME=qwen3.7-plus

# Agent-specific model configuration (optional overrides)
DATA_AGENT_MODEL=
PLANNING_AGENT_MODEL=
CREATIVE_AGENT_MODEL=
HOST_AGENT_MODEL=

# Agent URLs (internal, all localhost in single container)
DATA_AGENT_URL=http://localhost:8001
PLANNING_AGENT_URL=http://localhost:8002
CREATIVE_AGENT_URL=http://localhost:8003
HOST_AGENT_URL=http://localhost:8000

# Logging
LOG_LEVEL=INFO

# For OpenAI (alternative), uncomment:
# MODEL_API_KEY=your_openai_key_here
# MODEL_BASE_URL=
# MODEL_NAME=gpt-4-turbo

# For Ollama (local alternative), uncomment:
# MODEL_API_KEY=
# MODEL_BASE_URL=http://host.docker.internal:11434/v1
# MODEL_NAME=llama3
